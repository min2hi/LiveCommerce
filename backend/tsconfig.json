{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022"],
    "rootDir": "./",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "paths": {
      "@src/*": ["./src/*"],
      "@shared/*": ["./shared/*"],
      "@apps/*": ["./apps/*"],
      "node-pg-migrate": ["../node_modules/node-pg-migrate/dist/bundle/index.d.ts"]
    }
  },
  "include": [
    "apps/**/*",
    "src/**/*",
    "shared/**/*",
    "tests/**/*",
    "scratch/**/*",
    "seed-test-data.ts",
    "seed-auction.ts"
  ],
  "exclude": ["node_modules", "dist", "cmd", "internal", "pkg"]
}
