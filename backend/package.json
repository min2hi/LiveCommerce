{
  "name": "livecommerce-core",
  "version": "1.0.0",
  "description": "High-Concurrency Livestream E-commerce Backend",
  "main": "dist/apps/api-server/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child apps/api-server/main.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only --exit-child apps/order-worker/main.ts",
    "build": "tsc",
    "start": "node dist/apps/api-server/main.js",
    "start:worker": "node dist/apps/order-worker/main.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint apps/ src/ shared/ --max-warnings=0",
    "lint:fix": "eslint apps/ src/ shared/ --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "migrate:create": "node-pg-migrate create --migration-file-language sql",
    "migrate:up": "node migrate.js up",
    "migrate:down": "node migrate.js down"
  },
  "dependencies": {
    "@langchain/core": "^1.2.3",
    "@langchain/openai": "^1.5.5",
    "@langchain/pgvector": "*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "amqplib": "^2.0.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "langchain": "^1.5.3",
    "langsmith": "^0.8.3",
    "openai": "^6.48.0",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "redis": "^6.1.0",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@types/amqplib": "^0.10.6",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "node-pg-migrate": "^9.0.0",
    "prettier": "^3.9.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^7.0.2",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.2.0"
  }
}
