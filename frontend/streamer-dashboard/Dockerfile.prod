FROM node:22-alpine AS builder
WORKDIR /app
COPY package.json package-lock.json ./
COPY frontend/streamer-dashboard/package.json ./frontend/streamer-dashboard/
COPY backend/package.json ./backend/
RUN npm ci
COPY . .
RUN npm run streamer:build

FROM nginx:1.25-alpine
COPY --from=builder /app/frontend/streamer-dashboard/dist /usr/share/nginx/html
COPY frontend/streamer-dashboard/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 3002
CMD ["nginx", "-g", "daemon off;"]
