# ──────────────────────────────────────────
# LiveCommerce Core - Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# === Server ===
NODE_ENV=development
PORT=3000

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=livecommerce
POSTGRES_PASSWORD=secret
POSTGRES_DB=livecommerce

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === RabbitMQ ===
RABBITMQ_URL=amqp://livecommerce:secret@localhost:5672
RABBITMQ_EXCHANGE=order.exchange
RABBITMQ_QUEUE=order.queue
RABBITMQ_DLQ=order.dlq

# === OpenAI ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === JWT ===
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# === LangSmith (AgentOps tracing) ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=livecommerce-core

# === Rate Limiting ===
RATE_LIMIT_CHAT_MAX=5
RATE_LIMIT_CHECKOUT_MAX=1
RATE_LIMIT_WINDOW_MS=1000
