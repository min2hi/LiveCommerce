{
  "name": "livecommerce-monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "frontend/*"
  ],
  "scripts": {
    "dev": "npx concurrently -k -p \"[{name}]\" -n \"buyer,streamer,admin\" -c \"cyan,magenta,yellow\" \"npm run buyer:dev\" \"npm run streamer:dev\" \"npm run admin:dev\"",
    "dev:all": "npx concurrently -k -p \"[{name}]\" -n \"backend,buyer,streamer,admin\" -c \"blue,cyan,magenta,yellow\" \"npm run backend:dev\" \"npm run buyer:dev\" \"npm run streamer:dev\" \"npm run admin:dev\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prepare": "husky",
    "backend:dev": "npm run dev --workspace=backend",
    "backend:worker": "npm run dev:worker --workspace=backend",
    "backend:build": "npm run build --workspace=backend",
    "backend:type-check": "npm run type-check --workspace=backend",
    "backend:test": "npm run test --workspace=backend",
    "backend:test:coverage": "npm run test:coverage --workspace=backend",
    "backend:lint": "npm run lint --workspace=backend",
    "buyer:dev": "npm run dev --workspace=buyer-app",
    "buyer:build": "npm run build --workspace=buyer-app",
    "streamer:dev": "npm run dev --workspace=streamer-dashboard",
    "streamer:build": "npm run build --workspace=streamer-dashboard",
    "admin:dev": "npm run dev --workspace=admin-panel",
    "admin:build": "npm run build --workspace=admin-panel",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:reset": "docker compose down -v && docker compose up -d"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4"
  },
  "dependencies": {
    "postcss": "^8.5.19"
  }
}
